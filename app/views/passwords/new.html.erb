<div class="nc-auth-container">
  <div class="nc-auth-header">
    <%= link_to "NextChapter", root_path, class: "nc-auth-wordmark nc-type-headline-md" %>
  </div>

  <div class="nc-auth-card">
    <h1 class="nc-auth-card__title nc-type-headline-md">Reset Password</h1>

    <%= form_with url: passwords_path, local: true, class: "nc-auth-form" do |form| %>
      <div class="nc-auth-form-field">
        <%= form.label :email_address, "Email", class: "nc-auth-form-label nc-type-label-md" %>
        <%= form.email_field :email_address,
          required: true,
          autofocus: true,
          autocomplete: "username",
          value: params[:email_address],
          class: "nc-auth-form-input"
        %>
      </div>

      <%= form.submit "Email reset instructions", class: "nc-auth-button nc-type-label-md" %>
    <% end %>

    <div class="nc-auth-footer">
      <p class="nc-type-body-sm">
        Remember your password?
        <%= link_to "Log in", new_session_path, class: "nc-auth-footer-link" %>
      </p>
    </div>
  </div>
</div>
