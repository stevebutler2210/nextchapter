<div id="nomination_search">
  <%= form_with url: search_books_path,
        method: :get,
        class: "nc-search-form",
        data: { controller: "book-search", turbo_stream: true } do |f| %>
    <span class="nc-search-form__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="M20 20L16.65 16.65"></path>
      </svg>
    </span>
    <%= f.text_field :query,
          placeholder: "Search to Nominate",
          class: "nc-search-form__input",
          data: { book_search_target: "input", action: "input->book-search#debouncedSubmit" } %>
    <%= f.hidden_field :cycle_id, value: cycle.id %>
    <%= f.submit "Search", class: "nc-visually-hidden" %>
  <% end %>

  <div id="book-results" class="nc-search-results"></div>
</div>
