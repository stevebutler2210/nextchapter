<%= turbo_frame_tag "clubs_list" do %>
  <section class="nc-dashboard-form-wrap" aria-labelledby="new-club-heading">
    <h2 id="new-club-heading" class="nc-type-headline-md">Create a Club</h2>

    <% if @club.errors.any? %>
      <div class="nc-form-error">
        <p><%= pluralize(@club.errors.count, "error") %> prevented this club from being created:</p>
        <ul>
          <% @club.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @club, html: { class: "nc-dashboard-form" } do |form| %>
      <div class="nc-dashboard-form__field">
        <%= form.label :name, class: "nc-type-label-md" %>
        <%= form.text_field :name, class: "nc-dashboard-form__input" %>
      </div>

      <div class="nc-dashboard-form__field">
        <%= form.label :description, class: "nc-type-label-md" %>
        <%= form.text_area :description, class: "nc-dashboard-form__input nc-dashboard-form__textarea" %>
      </div>

      <div class="nc-dashboard-form__actions">
        <%= form.submit "Create Club", class: "nc-button nc-button--primary" %>
        <%= link_to "Cancel", clubs_path, class: "nc-button nc-button--tertiary" %>
      </div>
    <% end %>
  </section>
<% end %>
