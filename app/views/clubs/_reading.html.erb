<section class="nc-club-detail__section">
  <% current_book = cycle.winning_nomination&.book %>
  <article class="nc-current-book-callout">
    <div class="nc-book-cover-placeholder nc-book-cover-placeholder--lg" aria-hidden="true">
      <% if current_book&.cover_image_url.present? %>
        <%= image_tag current_book.cover_image_url, alt: current_book.title, class: "nc-book-cover-image" %>
      <% else %>
        <span><%= current_book&.title.to_s.first.to_s.upcase.presence || "B" %></span>
      <% end %>
    </div>

    <div>
      <h2 class="nc-current-book-callout__title"><%= current_book&.title.presence || "A book will be selected once voting closes" %></h2>
      <p class="nc-current-book-callout__author"><%= current_book&.authors.presence || "Author details will appear here." %></p>
      <p class="nc-current-book-callout__label">Currently Reading</p>
    </div>
  </article>

  <%= render "reading_log_entries_frame",
    cycle: cycle,
    reading_log_entry: reading_log_entry,
    reading_log_entries: reading_log_entries %>
</section>
