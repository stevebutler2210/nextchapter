<%= turbo_stream_from "club_#{@club.id}" %>

<% if @cycle&.nominating? %>
  <%= turbo_stream_from "cycle_#{@cycle.id}_nominations" %>
<% end %>

<% if @cycle&.voting? %>
  <%= turbo_stream_from "cycle_#{@cycle.id}_votes" %>
<% end %>

<%= turbo_frame_tag "club_details_#{@club.id}" do %>
  <section class="flex flex-col gap-8 max-w-3xl">
    <header class="nc-club-detail__header">
      <% if @is_owner %>
        <div class="absolute top-[15px] right-0 flex items-center gap-4 max-[820px]:static max-[820px]:justify-end">
          <%= link_to "Edit", edit_club_path(@club), class: "nc-club-detail__owner-link" %>
          <%= link_to "Delete", club_path(@club),
                class: "nc-club-detail__owner-link",
                data: { turbo_method: :delete, turbo_confirm: "Delete this club?", turbo_frame: "_top" } %>
        </div>
      <% end %>

      <h1 class="pr-[120px] max-[820px]:pr-0 nc-type-headline-md"><%= @club.name %></h1>
      <p class="nc-club-detail__description"><%= @club.description.presence || "No description provided." %></p>

      <div class="flex flex-wrap items-center justify-between gap-4">
        <%= render "clubs/member_avatars", club: @club, memberships: @memberships %>

        <div class="flex items-center gap-3 flex-wrap" data-controller="clipboard">
          <% state_name = @cycle&.state&.upcase || "UNKNOWN" %>
          <% state_class = @cycle&.state ? "nc-state-badge--#{@cycle.state}" : "nc-state-badge--voting" %>
          <span class="nc-state-badge <%= state_class %>"><%= state_name %></span>

          <% if @is_owner %>
            <span class="nc-visually-hidden" data-clipboard-target="source"><%= invite_url(signed_id: @invite_token) %></span>
            <button type="button"
                    class="nc-button nc-button--ghost"
                    data-clipboard-target="button"
                    data-action="clipboard#copy">Copy Invite Link</button>
          <% end %>
        </div>
      </div>
    </header>

    <% if @cycle&.nominating? %>
      <section class="nc-club-detail__section">
        <%= render "books/search_and_nominate", club: @club, cycle: @cycle %>

        <div id="nominations_list" class="nc-nominations-list">
          <% nominations = @cycle.nominations.includes(:book, :user) %>
          <% if nominations.any? %>
            <%= render nominations, partial: "nominations/nomination", as: :nomination %>
          <% else %>
            <p class="nc-empty-state">Nothing has been nominated yet. Start with the search bar above to add the first pick.</p>
          <% end %>
        </div>

        <% if @is_owner %>
          <%= button_to "Close Nominations", close_nominations_cycle_path(@cycle),
                method: :patch,
                class: "nc-button nc-button--tertiary",
                data: { turbo_frame: "_top" } %>
        <% end %>
      </section>
    <% end %>

    <% if @cycle&.voting? %>
      <section class="nc-club-detail__section">
        <% nominations = @cycle.nominations.includes(:book, :user, :votes) %>
        <%= render "nominations/voting_no_votes_notice",
              has_nominations: nominations.any?,
              has_votes: Vote.where(cycle_id: @cycle.id).exists? %>

        <div id="nominations_list" class="nc-nominations-list">
          <% if nominations.any? %>
            <%= render partial: "nominations/nomination",
                  collection: nominations,
                  as: :nomination,
                  locals: { current_user: Current.user } %>
          <% end %>
        </div>

        <% if @is_owner %>
          <%= button_to "Close Voting", close_voting_cycle_path(@cycle),
                method: :patch,
                class: "nc-button nc-button--tertiary",
                data: { turbo_frame: "_top" } %>
        <% end %>
      </section>
    <% end %>

    <% if @cycle&.reading? %>
      <%= render "reading",
            club: @club,
            cycle: @cycle,
            reading_log_entry: ReadingLogEntry.new,
            reading_log_entries: @cycle.reading_log_entries.where(user: Current.user).order(created_at: :desc) %>
    <% end %>
  </section>
<% end %>
