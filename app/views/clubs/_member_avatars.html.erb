<% memberships ||= club.memberships.includes(:user).order(:id) %>
<% avatar_tones = %w[primary tertiary surface-container-highest outline primary-container] %>

<div id="club_members_<%= club.id %>" class="nc-avatar-row" aria-label="Club members">
  <% memberships.each_with_index do |membership, index| %>
    <% user_presenter = present(membership.user) %>
    <% tone = avatar_tones[index % avatar_tones.length] %>
    <%= user_presenter.avatar_chip(tone) %>
  <% end %>
</div>
