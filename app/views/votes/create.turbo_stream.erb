<% @nomination.cycle.nominations.includes(:book, :user, :votes).each do |nomination| %>
  <%= turbo_stream.replace "nomination_#{nomination.id}" do %>
    <%= render "nominations/nomination",
          nomination: nomination,
          current_user: Current.user %>
  <% end %>
<% end %>

<%= turbo_stream.replace "voting_no_votes_notice" do %>
  <%= render "nominations/voting_no_votes_notice",
  has_nominations: Nomination.where(cycle_id: @nomination.cycle_id).exists?,
  has_votes: Vote.where(cycle_id: @nomination.cycle_id).exists? %>
<% end %>
